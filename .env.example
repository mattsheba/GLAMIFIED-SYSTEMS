# ============================================================
#  GLAMIFIED SYSTEMS — NETLIFY ENVIRONMENT VARIABLES
#  
#  DO NOT commit this file to GitHub or share it publicly.
#  Add each variable in:
#    Netlify Dashboard → Your Site → Site Configuration
#    → Environment Variables → Add variable
# ============================================================


# ── LENCO PAYMENT GATEWAY ────────────────────────────────────
# Your Lenco API secret key
# Where to find it: Lenco Dashboard → Settings → API Keys → Secret Key
LENCO_SECRET_KEY=your_lenco_secret_key_here

# Your Lenco webhook signing secret (for verifying webhook calls are genuine)
# Where to find it: Lenco Dashboard → Developers → Webhooks → Signing Secret
LENCO_WEBHOOK_SECRET=your_lenco_webhook_secret_here

# Lenco API base URL — use sandbox for testing, live for production
# Sandbox:    https://api.lenco.co/sandbox/v1   (test payments, no real money)
# Production: https://api.lenco.co/access/v1
LENCO_API_URL=https://api.lenco.co/access/v1


# ── LICENSE KEY GENERATOR ────────────────────────────────────
# A long random secret string used to sign all license keys.
# Generate one here: https://generate-secret.vercel.app/64
# IMPORTANT: Never change this after going live — it would invalidate existing keys.
GLAMIFIED_KEYGEN_SECRET=generate_a_long_random_string_here


# ── DOWNLOAD URLS ────────────────────────────────────────────
# Upload GlamifiedHR.exe to Cloudflare R2 (free), AWS S3, or any storage.
# These are the direct download links given to customers after purchase.
# Keep these unlisted/unguessable — only shared after confirmed payment.
DOWNLOAD_URL_BASIC=https://your-storage.com/glamifiedhr/GlamifiedHR-Basic-Setup.exe
DOWNLOAD_URL_PAYROLL=https://downloads.glamifiedsystems.com/GlamifiedHR_Setup.exe
DOWNLOAD_URL_SUITE=https://your-storage.com/glamifiedhr/GlamifiedHR-Suite-Setup.exe


# ── EMAIL (SMTP) ─────────────────────────────────────────────
# Use Gmail with an App Password (NOT your regular Gmail password).
# How to create a Gmail App Password:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Search for "App Passwords" → Create one for "Mail"
#   4. Paste the 16-character code below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info.glamifiedsystems@gmail.com
SMTP_PASS=your_16_char_gmail_app_password

# The "From" address shown in the email
FROM_EMAIL=info.glamifiedsystems@gmail.com

# Your personal email to receive sale notifications
ADMIN_EMAIL=info.glamifiedsystems@gmail.com


# ── SITE ─────────────────────────────────────────────────────
# Your live site URL (no trailing slash)
SITE_URL=https://glamifiedsystems.com
